{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": "./src",
    "ignoreDeprecations": "5.0",
    "strict": false,
    "noImplicitAny": false,
    "paths": {
      "@app/*": ["app/*"],
      "@features/*": ["features/*"],
      "@shared/*": ["shared/*"],
      "@assets/*": ["assets/*"],
      "@lib/*": ["lib/*"],
      "@navigation/*": ["navigation/*"],
      "react-native-view-shot": ["../node_modules/react-native-view-shot/lib/index.d.ts"]
    }
  },
  "exclude": ["__tests__", "src/**/*.test.ts"]
}
